# .env.example - V24D12-D-1 - Template de env vars para el proyecto MANAGER.
# Copia este archivo a .env y completa con tus valores reales LOCALES.
# NUNCA commitees .env al repo (esta en .gitignore, ver D-2).
# Los valores reales se setean en infra (Docker, K8s, AWS Secrets Manager).

# ============================================
# JWT (3 vars, SIN default, criticas)
# ============================================
# Genera con: openssl rand -base64 64
JWT_SECRET=change-me-please-use-openssl-rand-base64-64
# TTL del access token (en milisegundos? o segundos? ver JwtTokenProvider)
JWT_EXPIRATION=3600000
# TTL del refresh token
JWT_REFRESH_EXPIRATION=86400000

# ============================================
# PostgreSQL via Spring Boot auto-config (3 vars, 2 criticas sin default)
# ============================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ciberfootbolt
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me-please-local-dev-only

# ============================================
# Redis via Spring Boot auto-config (3 vars, 1 critica sin default)
# ============================================
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=change-me-please-local-dev-only

# ============================================
# Simulation feature flags (9 vars, CON default, no criticas)
# (Opcionales - el codigo usa default false si no se setean)
# ============================================
APP_SIMULATION_LEAGUE_USE_V23_ENGINE=false
APP_SIMULATION_LEAGUE_USE_V24_DETAILED_ENGINE=true
APP_SIMULATION_V24_PERSIST_DETAIL=true
APP_SIMULATION_V24_MUTATE_CAREER_STATE=false
APP_SIMULATION_V24_PERSIST_INJURIES=false
APP_SIMULATION_V24_PERSIST_FATIGUE=false
APP_SIMULATION_V24_PERSIST_DISCIPLINE=false
APP_SIMULATION_V24_PERSIST_FORM=false
SIMULATION_USE_V24_DETAILED_ENGINE=true
