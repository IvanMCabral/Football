# Colección de Pruebas API - Football Manager
# Archivo REST Client para VS Code
# Instala la extensión "REST Client" para usar este archivo directamente

### Variables
@baseUrl = http://localhost:8080/api/v1
@token = {{login.response.body.accessToken}}

### ====================================
### HEALTH CHECK
### ====================================

### Check API Health
GET http://localhost:8080/actuator/health

### ====================================
### AUTHENTICATION
### ====================================

### Register New User
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "username": "testuser",
  "password": "password123"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### ====================================
### TEAMS
### ====================================

### Create Team
# @name createTeam
POST {{baseUrl}}/teams
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Real Madrid",
  "country": "Spain",
  "budget": 500000000,
  "formation": "FORMATION_4_3_3"
}

### Get Team by ID
GET {{baseUrl}}/teams/{{createTeam.response.body.id}}
Authorization: Bearer {{token}}

### Get All User Teams
GET {{baseUrl}}/teams
Authorization: Bearer {{token}}

### Get Team Squad
GET {{baseUrl}}/teams/{{createTeam.response.body.id}}/squad
Authorization: Bearer {{token}}

### ====================================
### PLAYERS
### ====================================

### Create Player
# @name createPlayer
POST {{baseUrl}}/players
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Cristiano Ronaldo",
  "age": 38,
  "position": "ST",
  "attributes": {
    "attack": 95,
    "defense": 45,
    "technique": 92,
    "speed": 88,
    "stamina": 85,
    "mentality": 98
  },
  "marketValue": 25000000
}

### Get Player by ID
GET {{baseUrl}}/players/{{createPlayer.response.body.id}}
Authorization: Bearer {{token}}

### Get Available Players (Transfer Market)
GET {{baseUrl}}/players/available
Authorization: Bearer {{token}}

### Update Player
PUT {{baseUrl}}/players/{{createPlayer.response.body.id}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "energy": 80,
  "injured": false
}

### Add Player to Team
POST {{baseUrl}}/teams/{{createTeam.response.body.id}}/players/{{createPlayer.response.body.id}}
Authorization: Bearer {{token}}

### Remove Player from Team
DELETE {{baseUrl}}/teams/{{createTeam.response.body.id}}/players/{{createPlayer.response.body.id}}
Authorization: Bearer {{token}}

### ====================================
### MATCHES
### ====================================

### Create Match
# @name createMatch
POST {{baseUrl}}/matches
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "homeTeamId": "{{createTeam.response.body.id}}",
  "awayTeamId": "{{createTeam.response.body.id}}",
  "scheduledAt": "2025-12-30T20:00:00Z"
}

### Simulate Match
POST {{baseUrl}}/matches/{{createMatch.response.body.id}}/simulate
Authorization: Bearer {{token}}

### Get Match Details
GET {{baseUrl}}/matches/{{createMatch.response.body.id}}
Authorization: Bearer {{token}}

### Get Scheduled Matches
GET {{baseUrl}}/matches/scheduled
Authorization: Bearer {{token}}

### ====================================
### LEAGUES
### ====================================

### Create League (ADMIN only)
# @name createLeague
POST {{baseUrl}}/leagues
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "La Liga",
  "country": "Spain"
}

### Get League by ID
GET {{baseUrl}}/leagues/{{createLeague.response.body.id}}
Authorization: Bearer {{token}}

### Get All Leagues
GET {{baseUrl}}/leagues
Authorization: Bearer {{token}}

### Get League Standings
GET {{baseUrl}}/leagues/{{createLeague.response.body.id}}/standings
Authorization: Bearer {{token}}

### ====================================
### TRANSFERS
### ====================================

### Create Transfer Offer
# @name createTransfer
POST {{baseUrl}}/transfers
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "playerId": "{{createPlayer.response.body.id}}",
  "fromTeamId": "{{createTeam.response.body.id}}",
  "toTeamId": "{{createTeam.response.body.id}}",
  "offerAmount": 10000000
}

### Accept Transfer
POST {{baseUrl}}/transfers/{{createTransfer.response.body.id}}/accept
Authorization: Bearer {{token}}

### Reject Transfer
POST {{baseUrl}}/transfers/{{createTransfer.response.body.id}}/reject
Authorization: Bearer {{token}}

### Complete Transfer
POST {{baseUrl}}/transfers/{{createTransfer.response.body.id}}/complete
Authorization: Bearer {{token}}

### Get Pending Transfers
GET {{baseUrl}}/transfers/pending
Authorization: Bearer {{token}}
